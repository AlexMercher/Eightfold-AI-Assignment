# Application
APP_ENV=development
DEBUG=True

# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite:///candidate_transformer.db

# Resume Processing
MAX_UPLOAD_SIZE_MB=10
SPACY_MODEL=en_core_web_md
MIN_SECTION_CONFIDENCE=0.60

# Matching
SKILLS_FUZZY_THRESHOLD=80
NAME_MATCH_THRESHOLD=85
ENTITY_MATCH_THRESHOLD=90

# Logging
LOG_LEVEL=INFO